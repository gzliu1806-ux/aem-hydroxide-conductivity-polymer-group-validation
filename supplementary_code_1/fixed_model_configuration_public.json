{
  "schema_version": "1.0",
  "scope": "Fixed model-family benchmark under the primary polymer-group validation protocol",
  "target": "log10(reported hydroxide conductivity / mS cm^-1)",
  "random_seed": 42,
  "outer_validation": {
    "splitter": "GroupKFold",
    "n_splits": 5,
    "held_out_unit": "polymer_group",
    "outer_test_rows_used_for_preprocessing_or_selection": false
  },
  "preprocessing": {
    "fit_scope": "outer training fold only",
    "numeric_imputation": "median",
    "remove_zero_variance": true,
    "remove_exact_duplicates": true,
    "scalar_correlation_threshold": 0.98,
    "fingerprint_minimum_active_count": 2,
    "fingerprint_maximum_active_fraction": 0.995,
    "generic_scalar_maximum": 16,
    "binary_fingerprint_maximum": 96,
    "xor_fingerprint_maximum": 48,
    "count_fingerprint_maximum": 32,
    "additional_aem_descriptor_minimum": 18,
    "additional_aem_descriptor_maximum": 36,
    "aem_contrast_descriptor_minimum": 4,
    "aem_contrast_descriptor_maximum": 8,
    "selection_note": "Feature filtering and family-aware ranking used only the outer training fold. The resulting matrix was shared by all model families within that outer fold."
  },
  "sample_weighting": {
    "formula": "source_group_size^-0.15 * polymer_group_size^-0.10 * quality_weight^0.50 * collision_penalty * soft_warning_penalty",
    "normalization": "mean training-fold weight = 1",
    "collision_penalty": 0.9,
    "soft_warning_penalty_per_flag": 0.03,
    "application": "Applied where the estimator exposed a sample_weight interface; kNN and the scikit-learn 1.5.1 MLP fit were unweighted."
  },
  "training_only_grid_search": {
    "cv": 3,
    "scoring": "negative mean squared error",
    "models": [
      "Ridge",
      "ElasticNet",
      "KernelRidge (RBF)",
      "SVR (RBF)",
      "kNN"
    ]
  },
  "models": {
    "Ridge": {
      "scaling": "training-fold StandardScaler",
      "grid": {
        "alpha": [
          10.0,
          100.0,
          1000.0,
          10000.0
        ]
      }
    },
    "ElasticNet": {
      "scaling": "training-fold StandardScaler",
      "grid": {
        "alpha": [
          0.005,
          0.02,
          0.05,
          0.1
        ],
        "l1_ratio": [
          0.2,
          0.4,
          0.7
        ]
      },
      "parameters": {
        "max_iter": 20000
      }
    },
    "KernelRidge (RBF)": {
      "scaling": "training-fold StandardScaler",
      "grid": {
        "alpha": [
          0.1,
          1.0,
          10.0
        ],
        "gamma": [
          0.0005,
          0.001,
          0.003,
          0.01
        ]
      }
    },
    "SVR (RBF)": {
      "scaling": "training-fold StandardScaler",
      "grid": {
        "C": [
          3.0,
          10.0,
          30.0
        ],
        "epsilon": [
          0.03,
          0.05,
          0.1
        ],
        "gamma": [
          "scale",
          0.001,
          0.003
        ]
      }
    },
    "kNN": {
      "scaling": "training-fold StandardScaler",
      "grid": {
        "n_neighbors": [
          5,
          10,
          20,
          40
        ],
        "weights": [
          "distance",
          "uniform"
        ]
      }
    },
    "Random Forest": {
      "parameters": {
        "n_estimators": 500,
        "max_depth": null,
        "min_samples_leaf": 2,
        "max_features": "sqrt"
      }
    },
    "ExtraTrees": {
      "parameters": {
        "n_estimators": 500,
        "max_depth": null,
        "min_samples_leaf": 2,
        "max_features": "sqrt"
      }
    },
    "HistGradientBoosting": {
      "parameters": {
        "max_iter": 500,
        "learning_rate": 0.04,
        "l2_regularization": 0.1,
        "max_leaf_nodes": 31,
        "early_stopping": true
      }
    },
    "GradientBoosting": {
      "parameters": {
        "n_estimators": 500,
        "learning_rate": 0.03,
        "max_depth": 3,
        "subsample": 0.85,
        "min_samples_leaf": 2
      }
    },
    "MLP (3 seeds)": {
      "scaling": "training-fold feature and target standardization",
      "n_seeds": 3,
      "parameters": {
        "hidden_layer_sizes": [
          32
        ],
        "activation": "relu",
        "solver": "adam",
        "alpha": 1.0,
        "batch_size": 64,
        "learning_rate_init": 0.0007,
        "max_iter": 1000,
        "early_stopping": true,
        "validation_fraction": 0.15,
        "n_iter_no_change": 50
      }
    },
    "CatBoost": {
      "parameters": {
        "loss_function": "RMSE",
        "iterations": 900,
        "depth": 6,
        "learning_rate": 0.032,
        "l2_leaf_reg": 6.0
      }
    }
  }
}
